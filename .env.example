# ============================================
# NorthRadar - Configurações (sanitized)
# ============================================
# Copie este arquivo para .env e preencha os valores reais

# Operview API
OPERVIEW_CLIENT_ID=
OPERVIEW_DOMAIN_API=
OPERVIEW_SYNC_API=
OPERVIEW_SYNC_AUTH_KEY=

# Azure AD / MSAL
AZURE_TENANT_ID=
AZURE_AUTHORITY=

# Browser Automation
# true = sem janela visível, false = com janela
HEADLESS=false

# Intervalo de refresh do token em minutos (padrão: 110)
REFRESH_INTERVAL_MINUTES=110

# Caminho do Edge (ajuste se necessário)
EDGE_PATH=

# Token de acesso (preenchido automaticamente pela aplicação)
# Cole aqui manualmente se quiser pular a autenticação via browser
TOKEN_ACCESS=
