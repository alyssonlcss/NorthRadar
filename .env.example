# ============================================
# NorthRadar - Configurações (sanitized)
# ============================================
# Copie este arquivo para .env e preencha os valores reais

# Operview API
OPERVIEW_CLIENT_ID=
OPERVIEW_DOMAIN_API=
OPERVIEW_SYNC_API=
OPERVIEW_SYNC_AUTH_KEY=

# Azure AD / MSAL
AZURE_TENANT_ID=
AZURE_AUTHORITY=

# Browser Automation
# true = sem janela visível, false = com janela
HEADLESS=false

# Intervalo de refresh do token em minutos (padrão: 110)
REFRESH_INTERVAL_MINUTES=110

# Caminho do Edge (ajuste se necessário)
EDGE_PATH=

# Tags de equipes extras (siglas separadas por vírgula)
TAGS_EQUIPES_EXTRAS=-PD-,-ML-,-EP-,-LC-,-LL-,-CO-,-MP-,-IN-,-EN-,-MO-,-LV-

# Token de acesso (preenchido automaticamente pela aplicação)
# Cole aqui manualmente se quiser pular a autenticação via browser
TOKEN_ACCESS=

# ── Spotfire / Deslocamentos ──────────────────────────────────────
# URL da tela de login do Spotfire
SPOTFIRE_URL=http://elabziplra00.enelint.global:8090/spotfire/login.html#/

# Credenciais do Spotfire (separadas do Operview)
SPOTFIRE_USERNAME=
SPOTFIRE_PASSWORD=

# Polos a sincronizar (separados por vírgula)
SPOTFIRE_POLOS=ATLANTICO,DECEN,DNORT

# true = sem janela visível no Spotfire
SPOTFIRE_HEADLESS=false

# Timeout das operações do Spotfire em ms (padrão: 30000)
SPOTFIRE_TIMEOUT_MS=30000

# Intervalo de refresh dos deslocamentos em minutos (padrão: 30)
SPOTFIRE_REFRESH_INTERVAL_MINUTES=30

# Cooldown por usuário+filtro no endpoint on-demand em minutos (padrão: 10)
# Impede que o mesmo usuário acione o Spotfire para o mesmo filtro antes desse intervalo
DESLOCAMENTO_COOLDOWN_MINUTES=1
